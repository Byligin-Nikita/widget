<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Calendar.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Calendar.Controls"
    Title="Планер">

    <Grid x:Name="RootGrid" Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Transparent drag region in place of the system title bar -->
        <Border x:Name="AppTitleBar" Grid.Row="0" Grid.ColumnSpan="2" Background="Transparent"/>

        <!-- Tinted nav rail -->
        <Border Grid.Row="1" Grid.Column="0" Width="84" Background="{StaticResource NavRailBrush}"
                BorderBrush="{ThemeResource WidgetBorderBrush}" BorderThickness="0,0,1,0">
            <Grid Padding="10,8,10,16">
                <StackPanel x:Name="NavTop" Spacing="6" VerticalAlignment="Top" HorizontalAlignment="Center">
                    <controls:NavRailButton x:Name="NavHome" Section="ClockDate" Glyph="&#xE80F;" Label="Главная"
                                            Accent="{StaticResource HomeAccentBrush}" Tint="{StaticResource HomeTintBrush}"
                                            Selected="Nav_Selected"/>
                    <controls:NavRailButton x:Name="NavCalendar" Section="Calendar" Glyph="&#xE787;" Label="Календарь"
                                            Accent="{StaticResource CalAccentBrush}" Tint="{StaticResource CalTintBrush}"
                                            Selected="Nav_Selected"/>
                    <controls:NavRailButton x:Name="NavNotes" Section="Notes" Glyph="&#xE7C3;" Label="Заметки"
                                            Accent="{StaticResource NotesAccentBrush}" Tint="{StaticResource NotesTintBrush}"
                                            Selected="Nav_Selected"/>
                </StackPanel>
                <StackPanel x:Name="NavBottom" Spacing="6" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                    <controls:NavRailButton x:Name="NavSettings" Section="Settings" Glyph="&#xE713;" Label="Настройки"
                                            Accent="{StaticResource SettingsAccentBrush}" Tint="{StaticResource SettingsTintBrush}"
                                            Selected="Nav_Selected"/>
                </StackPanel>
            </Grid>
        </Border>

        <Frame x:Name="ContentFrame" Grid.Row="1" Grid.Column="1"/>
    </Grid>
</Window>
