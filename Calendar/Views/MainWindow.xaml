<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Calendar.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Планер">

    <Grid x:Name="RootGrid" Background="{StaticResource WidgetBackgroundBrush}"
          PointerPressed="RootGrid_PointerPressed"
          PointerMoved="RootGrid_PointerMoved"
          PointerReleased="RootGrid_PointerReleased"
          PointerCaptureLost="RootGrid_PointerReleased">

        <Border BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="32"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Drag bar -->
                <Grid Grid.Row="0" Background="#10000000"
                      PointerPressed="DragBar_PointerPressed"
                      PointerMoved="DragBar_PointerMoved"
                      PointerReleased="DragBar_PointerReleased">
                    <TextBlock Text="Планер" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0">
                        <Button x:Name="MinimizeBtn" Content="—" Click="MinimizeBtn_Click"
                                Width="28" Height="24" Padding="0" FontSize="12"/>
                    </StackPanel>
                </Grid>

                <NavigationView x:Name="NavView" Grid.Row="1"
                                IsBackButtonVisible="Collapsed"
                                IsSettingsVisible="False"
                                PaneDisplayMode="LeftCompact"
                                SelectionChanged="NavView_SelectionChanged"
                                ItemInvoked="NavView_ItemInvoked">

                    <NavigationView.MenuItems>
                        <NavigationViewItem Tag="ClockDate" Content="Время" Icon="Clock"/>
                        <NavigationViewItem Tag="Calendar" Content="Календарь" Icon="Calendar"/>
                        <NavigationViewItem Tag="Tasks" Content="Задачи" Icon="List"/>
                        <NavigationViewItem Tag="Reminders" Content="Напоминания" Icon="Important"/>
                    </NavigationView.MenuItems>

                    <NavigationView.FooterMenuItems>
                        <NavigationViewItem Tag="Settings" Content="Настройки" Icon="Setting"/>
                    </NavigationView.FooterMenuItems>

                    <Frame x:Name="ContentFrame"/>
                </NavigationView>
            </Grid>
        </Border>
    </Grid>
</Window>
