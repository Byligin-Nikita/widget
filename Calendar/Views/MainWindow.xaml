<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Calendar.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Планер">

    <Grid x:Name="RootGrid" Background="Transparent">
        <NavigationView x:Name="NavView" Background="Transparent"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        PaneDisplayMode="LeftCompact"
                        IsPaneToggleButtonVisible="False"
                        SelectionChanged="NavView_SelectionChanged"
                        ItemInvoked="NavView_ItemInvoked">

            <NavigationView.MenuItems>
                <NavigationViewItem Tag="ClockDate" Content="Главная" Icon="Home"/>
                <NavigationViewItem Tag="Calendar" Content="Календарь" Icon="Calendar"/>
                <NavigationViewItem Tag="Notes" Content="Заметки" Icon="Document"/>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Tag="Settings" Content="Настройки" Icon="Setting"/>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame"/>
        </NavigationView>
    </Grid>
</Window>
