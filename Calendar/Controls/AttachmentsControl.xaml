<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Calendar.Controls.AttachmentsControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Calendar.Controls">

    <Grid AllowDrop="True" DragOver="Root_DragOver" Drop="Root_Drop" RowSpacing="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <TextBlock Text="Вложения" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Button Content="Файл…" Click="AddFile_Click"/>
            <Button Content="Вставить" Click="Paste_Click"/>
        </StackPanel>

        <Grid Grid.Row="1" MinHeight="120" BorderBrush="{StaticResource WidgetBorderBrush}"
              BorderThickness="1" CornerRadius="6" Padding="4">
            <TextBlock x:Name="DropHint"
                       Text="Перетащите файлы сюда или вставьте картинку кнопкой «Вставить»"
                       Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap"
                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="12"/>
            <GridView x:Name="ItemsView" ItemsSource="{x:Bind Items}" SelectionMode="Extended"
                      CanDragItems="True" DragItemsStarting="Items_DragItemsStarting">
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="local:AttachmentItem">
                        <Grid Width="110" Height="110" Margin="4" CornerRadius="6" Background="#14808080"
                              ToolTipService.ToolTip="{x:Bind FileName}" DoubleTapped="Item_DoubleTapped">
                            <Grid.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Открыть" Click="Open_Click" Tag="{x:Bind Id}"/>
                                    <MenuFlyoutItem Text="Сохранить как…" Click="SaveAs_Click" Tag="{x:Bind Id}"/>
                                    <MenuFlyoutItem Text="Удалить" Click="RemoveMenu_Click" Tag="{x:Bind Id}"/>
                                </MenuFlyout>
                            </Grid.ContextFlyout>
                            <Image Source="{x:Bind Thumbnail}" Stretch="UniformToFill"
                                   Visibility="{x:Bind ImageVisibility}"/>
                            <StackPanel Visibility="{x:Bind FileVisibility}" Padding="6" Spacing="4"
                                        VerticalAlignment="Center" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE7C3;" FontSize="28" HorizontalAlignment="Center"/>
                                <TextBlock Text="{x:Bind FileName}" FontSize="11" MaxWidth="98"
                                           TextTrimming="CharacterEllipsis" TextAlignment="Center"/>
                            </StackPanel>
                            <Button Content="✕" Click="Remove_Click" Tag="{x:Bind Id}"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Width="24" Height="24" Padding="0" FontSize="10" Margin="2"/>
                        </Grid>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </Grid>
    </Grid>
</UserControl>
