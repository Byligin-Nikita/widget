<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Calendar.Controls.NavRailButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid x:Name="Root" Width="64" Height="58" CornerRadius="16" Background="Transparent"
          Tapped="OnTapped" PointerEntered="OnPointerEntered" PointerExited="OnPointerExited">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="3">
            <FontIcon x:Name="IconElement" FontSize="22"/>
            <TextBlock x:Name="LabelElement" FontSize="11" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
