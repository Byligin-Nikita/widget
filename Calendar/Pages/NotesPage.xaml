<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Calendar.Pages.NotesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Calendar.Controls"
    xmlns:vm="using:Calendar.ViewModels">

    <Grid Padding="12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <TextBlock Text="Заметки" Style="{StaticResource SectionTitleStyle}" VerticalAlignment="Center"/>
            <Button Content="+ Новая" Click="New_Click" HorizontalAlignment="Right"
                    Style="{StaticResource AccentButtonStyle}"/>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock x:Name="EmptyHint" Text="Создайте заметку кнопкой «+ Новая»"
                           Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" Margin="2,8"/>

                <ItemsControl x:Name="NotesItems">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:NoteRowViewModel">
                            <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                      Margin="0,0,0,6"
                                      IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                      Expanding="Expander_Expanding" Collapsed="Expander_Collapsed">
                                <Expander.Header>
                                    <Grid Padding="0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind DisplayTitle, Mode=OneWay}" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{x:Bind Preview, Mode=OneWay}"
                                                       Visibility="{x:Bind PreviewVisibility, Mode=OneWay}"
                                                       FontSize="12" Foreground="{StaticResource SecondaryTextBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <ItemsControl Grid.Column="1" ItemsSource="{x:Bind Badges, Mode=OneWay}"
                                                      VerticalAlignment="Center" Margin="8,0,8,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:NoteBadge">
                                                    <Border Width="20" Height="20" CornerRadius="5" Margin="-4,0,0,0"
                                                            Background="{x:Bind Background}"
                                                            BorderBrush="{StaticResource WidgetBackgroundBrush}"
                                                            BorderThickness="1.5">
                                                        <Grid>
                                                            <FontIcon Glyph="{x:Bind Glyph}" FontSize="11" Foreground="White"
                                                                      Visibility="{x:Bind GlyphVisibility}"/>
                                                            <TextBlock Text="{x:Bind Letter}" FontSize="11" FontWeight="SemiBold"
                                                                       Foreground="White" HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" Visibility="{x:Bind LetterVisibility}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Expander.Header>
                                <Expander.Content>
                                    <StackPanel Spacing="8" Padding="4,8,4,4">
                                        <TextBox Text="{x:Bind Title, Mode=OneWay}" PlaceholderText="Заголовок"
                                                 LostFocus="Title_LostFocus"/>
                                        <TextBox Text="{x:Bind Content, Mode=OneWay}" PlaceholderText="Текст заметки…"
                                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="120"
                                                 LostFocus="Content_LostFocus"/>
                                        <controls:AttachmentsControl/>
                                        <Button Content="Удалить заметку" Click="Delete_Click" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Expander.Content>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
