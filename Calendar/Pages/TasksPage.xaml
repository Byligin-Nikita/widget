<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Calendar.Pages.TasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Calendar.ViewModels">

    <Grid Padding="12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Задачи" Style="{StaticResource SectionTitleStyle}"/>

        <ComboBox x:Name="FilterCombo" Grid.Row="1" HorizontalAlignment="Stretch"
                  SelectionChanged="FilterCombo_SelectionChanged">
            <ComboBoxItem Content="Активные" Tag="Active" IsSelected="True"/>
            <ComboBoxItem Content="Сегодня" Tag="Today"/>
            <ComboBoxItem Content="Выполненные" Tag="Done"/>
        </ComboBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
            <TextBox x:Name="NewTaskBox" PlaceholderText="Новая задача..." Width="220" KeyDown="NewTaskBox_KeyDown"/>
            <Button Content="+" Click="AddTask_Click" Style="{StaticResource AccentButtonStyle}"/>
        </StackPanel>

        <TextBlock x:Name="EmptyText" Grid.Row="3" Text="Нет задач — добавьте новую выше"
                   Foreground="{StaticResource SecondaryTextBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="Collapsed"/>

        <ListView x:Name="TasksList" Grid.Row="3" SelectionMode="None"
                  IsItemClickEnabled="True" ItemClick="Task_Click">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:TaskRowViewModel">
                    <Grid ColumnSpacing="10" Padding="10,8" Margin="0,3"
                          Background="{ThemeResource CardBackgroundBrush}" CornerRadius="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" IsChecked="{x:Bind IsCompleted}"
                                  Click="Toggle_Click" Tag="{x:Bind Id}"
                                  MinWidth="0" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Spacing="5" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Title}" TextDecorations="{x:Bind StrikeThrough}"
                                       TextTrimming="CharacterEllipsis"/>
                            <ProgressBar Value="{x:Bind CompletionPercent}" Maximum="100" Height="3"/>
                        </StackPanel>
                        <TextBlock Grid.Column="2" Text="{x:Bind PercentText}" FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
