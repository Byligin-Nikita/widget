<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Calendar.Pages.TasksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Calendar.ViewModels">

    <Grid Padding="12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Задачи" Style="{StaticResource SectionTitleStyle}"/>

        <ComboBox x:Name="FilterCombo" Grid.Row="1" HorizontalAlignment="Stretch"
                  SelectionChanged="FilterCombo_SelectionChanged">
            <ComboBoxItem Content="Сегодня" Tag="Today"/>
            <ComboBoxItem Content="Все" Tag="All" IsSelected="True"/>
            <ComboBoxItem Content="Выполненные" Tag="Done"/>
        </ComboBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
            <TextBox x:Name="NewTaskBox" PlaceholderText="Новая задача..." Width="200"/>
            <Button Content="+" Click="AddTask_Click"/>
        </StackPanel>

        <TextBlock x:Name="EmptyText" Grid.Row="3" Text="Нет задач — добавьте новую выше"
                   Foreground="{StaticResource SecondaryTextBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="Collapsed"/>

        <ListView x:Name="TasksList" Grid.Row="3" SelectionMode="None">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:TaskRowViewModel">
                    <StackPanel Padding="8" Spacing="4" Background="#08000000" CornerRadius="4" Margin="0,2">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <CheckBox IsChecked="{x:Bind IsCompleted, Mode=TwoWay}"
                                      Checked="TaskCheck_Changed" Unchecked="TaskCheck_Changed"
                                      Tag="{x:Bind Id}"/>
                            <TextBlock Text="{x:Bind Title}" VerticalAlignment="Center"
                                       TextDecorations="{x:Bind StrikeThrough}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{x:Bind PercentText}" FontSize="12"
                                       Foreground="{StaticResource SecondaryTextBrush}" Width="36"/>
                            <Slider Minimum="0" Maximum="100" StepFrequency="25"
                                    Value="{x:Bind CompletionPercent, Mode=TwoWay}"
                                    ValueChanged="Progress_Changed" Tag="{x:Bind Id}"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
