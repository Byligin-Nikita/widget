<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Calendar.Pages.ClockDatePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="20">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="4">
            <TextBlock x:Name="TimeText" FontSize="48" FontWeight="Light" HorizontalAlignment="Center"/>
            <TextBlock x:Name="DateText" FontSize="18" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center"/>
            <TextBlock x:Name="DayText" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
