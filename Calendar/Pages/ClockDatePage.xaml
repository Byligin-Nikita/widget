<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Calendar.Pages.ClockDatePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="20" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="18">

            <!-- Header: clock + date + next reminder -->
            <StackPanel Spacing="2">
                <TextBlock x:Name="TimeText" FontSize="40" FontWeight="Light"/>
                <TextBlock x:Name="DateText" FontSize="15" Foreground="{StaticResource SecondaryTextBrush}"/>
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,6,0,0">
                    <FontIcon Glyph="&#xE121;" FontSize="13" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="NextReminderText" FontSize="13" VerticalAlignment="Center"
                               Foreground="{StaticResource SecondaryTextBrush}" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </StackPanel>

            <!-- Action tiles -->
            <VariableSizedWrapGrid Orientation="Horizontal" ItemWidth="180" ItemHeight="118">

                <Button Tag="Calendar" Click="Tile_Click" Style="{StaticResource TileButtonStyle}">
                    <StackPanel Spacing="6">
                        <FontIcon Glyph="&#xE787;" FontSize="24" HorizontalAlignment="Left" Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="Календарь" FontWeight="SemiBold"/>
                        <TextBlock x:Name="CalendarSub" FontSize="12" TextWrapping="Wrap"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Button>

                <Button Tag="Notes" Click="Tile_Click" Style="{StaticResource TileButtonStyle}">
                    <StackPanel Spacing="6">
                        <FontIcon Glyph="&#xE7C3;" FontSize="24" HorizontalAlignment="Left" Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="Заметки" FontWeight="SemiBold"/>
                        <TextBlock x:Name="NotesSub" FontSize="12" TextWrapping="Wrap"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Button>

                <Button Tag="QuickAdd" Click="Tile_Click" Style="{StaticResource TileButtonStyle}">
                    <StackPanel Spacing="6">
                        <FontIcon Glyph="&#xE710;" FontSize="24" HorizontalAlignment="Left" Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="Быстро добавить" FontWeight="SemiBold"/>
                        <TextBlock Text="Задача или напоминание" FontSize="12" TextWrapping="Wrap"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Button>

                <Button Tag="Settings" Click="Tile_Click" Style="{StaticResource TileButtonStyle}">
                    <StackPanel Spacing="6">
                        <FontIcon Glyph="&#xE713;" FontSize="24" HorizontalAlignment="Left" Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="Настройки" FontWeight="SemiBold"/>
                        <TextBlock Text="Хоткеи, автозапуск, тема" FontSize="12" TextWrapping="Wrap"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Button>

            </VariableSizedWrapGrid>
        </StackPanel>
    </ScrollViewer>
</Page>
