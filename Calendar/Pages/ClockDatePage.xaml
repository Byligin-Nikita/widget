<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Calendar.Pages.ClockDatePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="22,22,22,28" Spacing="18" HorizontalAlignment="Stretch">

            <!-- Hero: big date + jade orb -->
            <Border Style="{StaticResource CardStyle}" Padding="0" Height="172" MaxWidth="620"
                    HorizontalAlignment="Stretch">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="26,0,8,0" Spacing="0">
                        <TextBlock x:Name="WeekdayText" FontSize="28" FontWeight="SemiBold"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                        <TextBlock x:Name="DayNumberText" FontSize="64" FontWeight="Bold" Margin="0,-8,0,4"/>
                        <TextBlock x:Name="TimeText" FontSize="14" Foreground="{StaticResource SecondaryTextBrush}"/>
                        <TextBlock x:Name="DateText" FontSize="13" Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>

                    <Ellipse Grid.Column="1" Width="184" Height="184" Fill="{StaticResource OrbBrush}"
                             VerticalAlignment="Center" Margin="0,0,-38,0"/>
                </Grid>
            </Border>

            <!-- Search-style quick-add pill -->
            <StackPanel HorizontalAlignment="Stretch" MaxWidth="620" Spacing="4">
                <Border CornerRadius="24" Height="46" Padding="18,0"
                        Background="{ThemeResource CardBackgroundBrush}"
                        BorderBrush="{ThemeResource WidgetBorderBrush}" BorderThickness="1">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE721;" FontSize="16" VerticalAlignment="Center"
                                  Foreground="{StaticResource SecondaryTextBrush}"/>
                        <TextBox x:Name="QuickBox" Grid.Column="1" BorderThickness="0" Background="Transparent"
                                 VerticalAlignment="Center" KeyDown="QuickBox_KeyDown"
                                 PlaceholderText="Быстро добавить — напр.: позвонить маме завтра в 18"/>
                    </Grid>
                </Border>
                <TextBlock x:Name="QuickHint" Visibility="Collapsed" FontSize="12"
                           HorizontalAlignment="Center" Foreground="{StaticResource AccentBrush}"/>
            </StackPanel>

            <!-- Tiles -->
            <VariableSizedWrapGrid x:Name="Tiles" Orientation="Horizontal"
                                   ItemWidth="152" ItemHeight="122" HorizontalAlignment="Center">

                <Button Tag="Calendar" Click="Tile_Click" Style="{StaticResource TileButtonStyle}" Background="#2A5B8DEF">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <FontIcon Glyph="&#xE787;" FontSize="26" HorizontalAlignment="Center" Foreground="#5B8DEF"/>
                        <TextBlock Text="Календарь" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="CalendarSub" FontSize="11" HorizontalAlignment="Center" TextAlignment="Center"
                                   TextWrapping="Wrap" Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Button>

                <Button Tag="Notes" Click="Tile_Click" Style="{StaticResource TileButtonStyle}" Background="#2AE8975A">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <FontIcon Glyph="&#xE7C3;" FontSize="26" HorizontalAlignment="Center" Foreground="#E8975A"/>
                        <TextBlock Text="Заметки" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="NotesSub" FontSize="11" HorizontalAlignment="Center" TextAlignment="Center"
                                   TextWrapping="Wrap" Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Button>

                <Button Tag="Calendar" Click="Tile_Click" Style="{StaticResource TileButtonStyle}" Background="#2AE8769B">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <FontIcon Glyph="&#xE823;" FontSize="26" HorizontalAlignment="Center" Foreground="#E8769B"/>
                        <TextBlock Text="Напоминания" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="RemindersSub" FontSize="11" HorizontalAlignment="Center" TextAlignment="Center"
                                   TextWrapping="Wrap" Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Button>

                <Button Tag="QuickAdd" Click="Tile_Click" Style="{StaticResource TileButtonStyle}" Background="#2A2FA37C">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="26" HorizontalAlignment="Center" Foreground="#2FA37C"/>
                        <TextBlock Text="Быстро добавить" FontWeight="SemiBold" HorizontalAlignment="Center" TextAlignment="Center"/>
                        <TextBlock Text="Задача или напоминание" FontSize="11" HorizontalAlignment="Center" TextAlignment="Center"
                                   TextWrapping="Wrap" Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Button>

                <Button Tag="Settings" Click="Tile_Click" Style="{StaticResource TileButtonStyle}" Background="#2AA98EDA">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <FontIcon Glyph="&#xE713;" FontSize="26" HorizontalAlignment="Center" Foreground="#A98EDA"/>
                        <TextBlock Text="Настройки" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="Хоткеи, тема, автозапуск" FontSize="11" HorizontalAlignment="Center" TextAlignment="Center"
                                   TextWrapping="Wrap" Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Button>

                <Button Tag="Minimize" Click="Tile_Click" Style="{StaticResource TileButtonStyle}" Background="#2A4FB0C6">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <FontIcon Glyph="&#xE921;" FontSize="26" HorizontalAlignment="Center" Foreground="#4FB0C6"/>
                        <TextBlock Text="Свернуть в трей" FontWeight="SemiBold" HorizontalAlignment="Center" TextAlignment="Center"/>
                        <TextBlock Text="Win + Shift + Z — вернуть" FontSize="11" HorizontalAlignment="Center" TextAlignment="Center"
                                   TextWrapping="Wrap" Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Button>

            </VariableSizedWrapGrid>
        </StackPanel>
    </ScrollViewer>
</Page>
