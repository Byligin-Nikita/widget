<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Calendar.Pages.CalendarPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Calendar.Pages">

    <Grid Padding="12" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Month navigation -->
        <Grid>
            <StackPanel Orientation="Horizontal" Spacing="2" HorizontalAlignment="Left">
                <Button Click="Prev_Click" Width="32" Height="32" Padding="0"
                        Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Предыдущий месяц">
                    <FontIcon Glyph="&#xE76B;" FontSize="12"/>
                </Button>
                <TextBlock x:Name="MonthLabel" FontSize="18" FontWeight="SemiBold"
                           VerticalAlignment="Center" MinWidth="150" TextAlignment="Center"/>
                <Button Click="Next_Click" Width="32" Height="32" Padding="0"
                        Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Следующий месяц">
                    <FontIcon Glyph="&#xE76C;" FontSize="12"/>
                </Button>
            </StackPanel>
            <Button Content="Сегодня" Click="Today_Click" HorizontalAlignment="Right"/>
        </Grid>

        <!-- Weekday header -->
        <Grid x:Name="WeekHeader" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Пн" TextAlignment="Center" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}"/>
            <TextBlock Grid.Column="1" Text="Вт" TextAlignment="Center" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}"/>
            <TextBlock Grid.Column="2" Text="Ср" TextAlignment="Center" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}"/>
            <TextBlock Grid.Column="3" Text="Чт" TextAlignment="Center" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}"/>
            <TextBlock Grid.Column="4" Text="Пт" TextAlignment="Center" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}"/>
            <TextBlock Grid.Column="5" Text="Сб" TextAlignment="Center" FontSize="12" Foreground="{StaticResource AccentBrush}"/>
            <TextBlock Grid.Column="6" Text="Вс" TextAlignment="Center" FontSize="12" Foreground="{StaticResource AccentBrush}"/>
        </Grid>

        <!-- Day cells (filled in code) -->
        <Grid x:Name="DayGrid" Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition/><RowDefinition/><RowDefinition/>
                <RowDefinition/><RowDefinition/><RowDefinition/>
            </Grid.RowDefinitions>
        </Grid>

        <!-- Day detail (revealed on double-click) -->
        <Border x:Name="DetailPanel" Grid.Row="3" Visibility="Collapsed"
                BorderBrush="{StaticResource WidgetBorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="10" Margin="0,4,0,0">
            <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid>
                    <TextBlock x:Name="DetailTitle" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Button Click="CloseDetail_Click" Content="✕" HorizontalAlignment="Right"
                            Background="Transparent" BorderThickness="0" Width="28" Height="28"
                            Padding="0" FontSize="12"/>
                </Grid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="+ Задача" Click="AddTask_Click" Style="{StaticResource AccentButtonStyle}"/>
                    <Button Content="+ Напоминание" Click="AddReminder_Click"/>
                </StackPanel>

                <Grid Grid.Row="2">
                    <TextBlock x:Name="DayEmpty" Text="На этот день ничего нет"
                               Foreground="{StaticResource SecondaryTextBrush}"
                               HorizontalAlignment="Center" Margin="0,12,0,0" Visibility="Collapsed"/>
                    <ListView x:Name="DayItemsList" SelectionMode="None"
                              IsItemClickEnabled="True" ItemClick="DayItem_Click">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:DayItem">
                                <Grid ColumnSpacing="10" Padding="2,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Glyph="{x:Bind Glyph}" FontSize="14"
                                              Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Title}" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{x:Bind Subtitle}" FontSize="11"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   Visibility="{x:Bind SubtitleVisibility}"/>
                                    </StackPanel>
                                    <FontIcon Grid.Column="2" Glyph="&#xE70F;" FontSize="11"
                                              Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
