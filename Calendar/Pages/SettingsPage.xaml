<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Calendar.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Padding="16" VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled" HorizontalScrollMode="Disabled">
        <StackPanel Spacing="14" MaxWidth="620" HorizontalAlignment="Left">
            <TextBlock Text="Настройки" Style="{StaticResource SectionTitleStyle}"/>

            <!-- Appearance -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Оформление" FontWeight="SemiBold"/>

                    <Grid>
                        <TextBlock Text="Акцентный цвет" VerticalAlignment="Center"/>
                        <Button x:Name="AccentButton" HorizontalAlignment="Right" Width="48" Height="32"
                                Padding="0" CornerRadius="10">
                            <Border x:Name="AccentSwatch" Width="30" Height="18" CornerRadius="6"/>
                            <Button.Flyout>
                                <Flyout Closed="AccentFlyout_Closed">
                                    <StackPanel Spacing="12">
                                        <ColorPicker x:Name="AccentPicker" Width="280"
                                                     IsAlphaEnabled="False" IsColorSliderVisible="True"
                                                     IsHexInputVisible="True" IsColorChannelTextInputVisible="False"
                                                     ColorChanged="AccentPicker_ColorChanged"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                            <Button Tag="#2FA37C" Click="Preset_Click" Width="28" Height="28" Padding="0" CornerRadius="14" Background="#2FA37C"/>
                                            <Button Tag="#5B8DEF" Click="Preset_Click" Width="28" Height="28" Padding="0" CornerRadius="14" Background="#5B8DEF"/>
                                            <Button Tag="#A98EDA" Click="Preset_Click" Width="28" Height="28" Padding="0" CornerRadius="14" Background="#A98EDA"/>
                                            <Button Tag="#E8975A" Click="Preset_Click" Width="28" Height="28" Padding="0" CornerRadius="14" Background="#E8975A"/>
                                            <Button Tag="#E8769B" Click="Preset_Click" Width="28" Height="28" Padding="0" CornerRadius="14" Background="#E8769B"/>
                                            <Button Tag="#4FB0C6" Click="Preset_Click" Width="28" Height="28" Padding="0" CornerRadius="14" Background="#4FB0C6"/>
                                            <Button Tag="#6E7B74" Click="Preset_Click" Width="28" Height="28" Padding="0" CornerRadius="14" Background="#6E7B74"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>

                    <StackPanel Spacing="2">
                        <Grid>
                            <TextBlock Text="Прозрачность" VerticalAlignment="Center"/>
                            <TextBlock x:Name="OpacityValue" HorizontalAlignment="Right"
                                       Foreground="{StaticResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                        </Grid>
                        <Slider x:Name="OpacitySlider" Minimum="40" Maximum="100" StepFrequency="1"
                                ValueChanged="OpacitySlider_ValueChanged"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Behaviour -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="14">
                    <ToggleSwitch x:Name="AlwaysOnTopSwitch" Header="Поверх всех окон"
                                  OnContent="Вкл" OffContent="Выкл" Toggled="AlwaysOnTopSwitch_Toggled"/>
                    <ToggleSwitch x:Name="AutostartSwitch" Header="Запуск с Windows"
                                  OnContent="Вкл" OffContent="Выкл" Toggled="AutostartSwitch_Toggled"/>
                    <ComboBox x:Name="ThemeCombo" Header="Тема" SelectionChanged="ThemeCombo_SelectionChanged">
                        <ComboBoxItem Content="Системная" Tag="System"/>
                        <ComboBoxItem Content="Светлая" Tag="Light"/>
                        <ComboBoxItem Content="Тёмная" Tag="Dark"/>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- Hotkeys -->
            <Border Style="{StaticResource CardStyle}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Горячие клавиши" FontWeight="SemiBold"/>
                    <TextBlock Text="Win+Shift+Q — новая заметка" FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                    <TextBlock Text="Win+Shift+Z — показать/скрыть виджет" FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                </StackPanel>
            </Border>

            <TextBlock Text="Данные хранятся локально. Синхронизация с облаком — в следующих версиях."
                       FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap"/>
        </StackPanel>
    </ScrollViewer>
</Page>
