<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Palette: Soft blue #97C2EC / Light taupe #D6D0C2 / Black #1F1F1F / White #FFFFFF -->
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="WidgetBackgroundBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="WidgetBorderBrush" Color="#D6D0C2"/>
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#7C7873"/>
            <SolidColorBrush x:Key="CompletedTextBrush" Color="#A8A39A"/>
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#EAE7DF"/>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="WidgetBackgroundBrush" Color="#1F1F1F"/>
            <SolidColorBrush x:Key="WidgetBorderBrush" Color="#28FFFFFF"/>
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#A29C90"/>
            <SolidColorBrush x:Key="CompletedTextBrush" Color="#80FFFFFF"/>
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#14FFFFFF"/>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- ===== Soft-blue accent (same both themes) ===== -->
    <Color x:Key="AppAccentColor">#97C2EC</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="#97C2EC"/>
    <SolidColorBrush x:Key="OverdueBrush" Color="#D9534F"/>

    <!-- Recolor the WinUI system-accent family -> soft blue -->
    <Color x:Key="SystemAccentColor">#97C2EC</Color>
    <Color x:Key="SystemAccentColorLight1">#A7CDF0</Color>
    <Color x:Key="SystemAccentColorLight2">#B8D8F4</Color>
    <Color x:Key="SystemAccentColorLight3">#C9E2F7</Color>
    <Color x:Key="SystemAccentColorDark1">#7DAEDF</Color>
    <Color x:Key="SystemAccentColorDark2">#6699D6</Color>
    <Color x:Key="SystemAccentColorDark3">#4F84C9</Color>

    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#97C2EC"/>
    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#88B7E6"/>
    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#7DAEDF"/>

    <!-- Dark text on the light-blue accent for readability -->
    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush" Color="#1F1F1F"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorSecondaryBrush" Color="#1F1F1F"/>

    <!-- NavigationView blends into the solid background -->
    <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent"/>

    <!-- ===== Typography ===== -->
    <x:Double x:Key="SectionTitleFontSize">18</x:Double>
    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource SectionTitleFontSize}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>
</ResourceDictionary>
