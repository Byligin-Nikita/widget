<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         Jade + warm cream. Premium, airy, soft look:
         calm warm background, big white rounded cards, a jade
         gradient "orb" accent. Each section keeps its own tone.
         Base/brand color = jade green.
         ============================================================ -->

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="WidgetBackgroundBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="WidgetBorderBrush" Color="#CFE2D7"/>
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#7F857F"/>
            <SolidColorBrush x:Key="CompletedTextBrush" Color="#AEB3AC"/>
            <SolidColorBrush x:Key="MutedIconBrush" Color="#9AA09A"/>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="WidgetBackgroundBrush" Color="#1C221E"/>
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1C221E"/>
            <SolidColorBrush x:Key="WidgetBorderBrush" Color="#2B332D"/>
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#919A92"/>
            <SolidColorBrush x:Key="CompletedTextBrush" Color="#666E66"/>
            <SolidColorBrush x:Key="MutedIconBrush" Color="#828A82"/>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- ===== Section tones (accent + translucent tint, theme-agnostic) ===== -->
    <SolidColorBrush x:Key="HomeAccentBrush" Color="#2FA37C"/>
    <SolidColorBrush x:Key="HomeTintBrush" Color="#2A2FA37C"/>
    <SolidColorBrush x:Key="CalAccentBrush" Color="#5B8DEF"/>
    <SolidColorBrush x:Key="CalTintBrush" Color="#2A5B8DEF"/>
    <SolidColorBrush x:Key="NotesAccentBrush" Color="#E8975A"/>
    <SolidColorBrush x:Key="NotesTintBrush" Color="#2AE8975A"/>
    <SolidColorBrush x:Key="SettingsAccentBrush" Color="#A98EDA"/>
    <SolidColorBrush x:Key="SettingsTintBrush" Color="#2AA98EDA"/>

    <!-- Dynamic surfaces: top-level so ThemeManager can recolor them live
         (derived from accent + opacity at runtime). -->
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#DFEEE7"/>
    <SolidColorBrush x:Key="NavRailBrush" Color="#E9F4EE"/>

    <!-- ===== Primary / brand accent = jade ===== -->
    <Color x:Key="AppAccentColor">#2FA37C</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="#2FA37C"/>
    <SolidColorBrush x:Key="OverdueBrush" Color="#E5707E"/>

    <!-- Jade gradient for the home "orb" -->
    <LinearGradientBrush x:Key="OrbBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#6FD9B4" Offset="0.0"/>
        <GradientStop Color="#2FA37C" Offset="0.65"/>
        <GradientStop Color="#1E7E5C" Offset="1.0"/>
    </LinearGradientBrush>

    <!-- Recolor the WinUI system-accent family -> jade -->
    <Color x:Key="SystemAccentColor">#2FA37C</Color>
    <Color x:Key="SystemAccentColorLight1">#46B591</Color>
    <Color x:Key="SystemAccentColorLight2">#62C6A4</Color>
    <Color x:Key="SystemAccentColorLight3">#84D6BB</Color>
    <Color x:Key="SystemAccentColorDark1">#268A69</Color>
    <Color x:Key="SystemAccentColorDark2">#1E7155</Color>
    <Color x:Key="SystemAccentColorDark3">#155840</Color>

    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#2FA37C"/>
    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#2A9472"/>
    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#268A69"/>

    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorSecondaryBrush" Color="#F0F0F0"/>

    <!-- Make standard controls follow the user's accent: alias their accent
         brushes to AccentBrush (and on-accent parts to TextOnAccent...) so that
         mutating those two brushes at runtime recolours toggles, sliders,
         checkboxes, radios and progress bars live. -->
    <StaticResource x:Key="ToggleSwitchFillOn" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="ToggleSwitchFillOnPointerOver" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="ToggleSwitchFillOnPressed" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="ToggleSwitchStrokeOn" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="ToggleSwitchStrokeOnPointerOver" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="ToggleSwitchStrokeOnPressed" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="ToggleSwitchKnobFillOn" ResourceKey="TextOnAccentFillColorPrimaryBrush"/>
    <StaticResource x:Key="ToggleSwitchKnobFillOnPointerOver" ResourceKey="TextOnAccentFillColorPrimaryBrush"/>
    <StaticResource x:Key="ToggleSwitchKnobFillOnPressed" ResourceKey="TextOnAccentFillColorPrimaryBrush"/>

    <StaticResource x:Key="SliderTrackValueFill" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="SliderTrackValueFillPointerOver" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="SliderTrackValueFillPressed" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="SliderThumbBackground" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="SliderThumbBackgroundPointerOver" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="SliderThumbBackgroundPressed" ResourceKey="AccentBrush"/>

    <StaticResource x:Key="CheckBoxCheckBackgroundFillChecked" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="CheckBoxCheckBackgroundFillCheckedPointerOver" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="CheckBoxCheckBackgroundFillCheckedPressed" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="CheckBoxCheckBackgroundStrokeChecked" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="CheckBoxCheckBackgroundStrokeCheckedPointerOver" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="CheckBoxCheckBackgroundStrokeCheckedPressed" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="CheckBoxCheckGlyphForegroundChecked" ResourceKey="TextOnAccentFillColorPrimaryBrush"/>
    <StaticResource x:Key="CheckBoxCheckGlyphForegroundCheckedPointerOver" ResourceKey="TextOnAccentFillColorPrimaryBrush"/>
    <StaticResource x:Key="CheckBoxCheckGlyphForegroundCheckedPressed" ResourceKey="TextOnAccentFillColorPrimaryBrush"/>

    <StaticResource x:Key="RadioButtonOuterEllipseCheckedFill" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="RadioButtonOuterEllipseCheckedFillPointerOver" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="RadioButtonOuterEllipseCheckedFillPressed" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="RadioButtonOuterEllipseCheckedStroke" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="RadioButtonOuterEllipseCheckedStrokePointerOver" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="RadioButtonOuterEllipseCheckedStrokePressed" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="RadioButtonCheckGlyphFill" ResourceKey="TextOnAccentFillColorPrimaryBrush"/>
    <StaticResource x:Key="RadioButtonCheckGlyphFillPointerOver" ResourceKey="TextOnAccentFillColorPrimaryBrush"/>
    <StaticResource x:Key="RadioButtonCheckGlyphFillPressed" ResourceKey="TextOnAccentFillColorPrimaryBrush"/>

    <StaticResource x:Key="ProgressBarForeground" ResourceKey="AccentBrush"/>

    <StaticResource x:Key="AccentButtonBackground" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="AccentButtonBackgroundPointerOver" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="AccentButtonBackgroundPressed" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="AccentButtonBorderBrush" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="AccentButtonBorderBrushPointerOver" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="AccentButtonBorderBrushPressed" ResourceKey="AccentBrush"/>
    <StaticResource x:Key="AccentButtonForeground" ResourceKey="TextOnAccentFillColorPrimaryBrush"/>
    <StaticResource x:Key="AccentButtonForegroundPointerOver" ResourceKey="TextOnAccentFillColorPrimaryBrush"/>
    <StaticResource x:Key="AccentButtonForegroundPressed" ResourceKey="TextOnAccentFillColorPrimaryBrush"/>

    <!-- ===== Generous, soft corners ===== -->
    <CornerRadius x:Key="ControlCornerRadius">11</CornerRadius>
    <CornerRadius x:Key="OverlayCornerRadius">16</CornerRadius>

    <!-- ===== Typography ===== -->
    <x:Double x:Key="SectionTitleFontSize">24</x:Double>
    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource SectionTitleFontSize}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin" Value="2,0,0,8"/>
    </Style>

    <!-- ===== Grouped card ===== -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource WidgetBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <!-- ===== Dashboard tile (soft tinted, centered) ===== -->
    <Style x:Key="TileButtonStyle" TargetType="Button">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="18"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Margin" Value="6"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
</ResourceDictionary>
