<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Theme-dependent surfaces & text (transparent surfaces let Mica show through) -->
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="WidgetBackgroundBrush" Color="Transparent"/>
            <SolidColorBrush x:Key="WidgetBorderBrush" Color="#22000000"/>
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#6B6B70"/>
            <SolidColorBrush x:Key="CompletedTextBrush" Color="#9A9AA0"/>
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#0C000000"/>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="WidgetBackgroundBrush" Color="Transparent"/>
            <SolidColorBrush x:Key="WidgetBorderBrush" Color="#28FFFFFF"/>
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#B4B4BC"/>
            <SolidColorBrush x:Key="CompletedTextBrush" Color="#80FFFFFF"/>
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#16FFFFFF"/>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- ===== Fuchsia accent (same in both themes) ===== -->
    <Color x:Key="FuchsiaAccent">#E0218A</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="#E0218A"/>

    <!-- Recolor the WinUI system-accent family so built-in controls go fuchsia -->
    <Color x:Key="SystemAccentColor">#E0218A</Color>
    <Color x:Key="SystemAccentColorLight1">#E84BA3</Color>
    <Color x:Key="SystemAccentColorLight2">#EF74BB</Color>
    <Color x:Key="SystemAccentColorLight3">#F49ED2</Color>
    <Color x:Key="SystemAccentColorDark1">#C01477</Color>
    <Color x:Key="SystemAccentColorDark2">#9C0F61</Color>
    <Color x:Key="SystemAccentColorDark3">#76094A</Color>

    <!-- Accent fill brushes used by buttons / toggles / sliders -->
    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#E0218A"/>
    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#CF1E80"/>
    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#B81576"/>

    <!-- Make NavigationView blend into Mica -->
    <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent"/>

    <!-- ===== Typography ===== -->
    <x:Double x:Key="SectionTitleFontSize">18</x:Double>
    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource SectionTitleFontSize}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>
</ResourceDictionary>
