<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         iOS-inspired soft design. Grouped surfaces: a calm page
         background with white rounded "cards". Each section has its
         own soft pastel tone (accent + translucent tint).
         ============================================================ -->

    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F2F3F7"/>
            <SolidColorBrush x:Key="NavRailBrush" Color="#FBFBFD"/>
            <SolidColorBrush x:Key="WidgetBackgroundBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="WidgetBorderBrush" Color="#E4E4EA"/>
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#8A8A8E"/>
            <SolidColorBrush x:Key="CompletedTextBrush" Color="#B0B0B5"/>
            <SolidColorBrush x:Key="MutedIconBrush" Color="#9A9AA0"/>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#161618"/>
            <SolidColorBrush x:Key="NavRailBrush" Color="#1F1F22"/>
            <SolidColorBrush x:Key="WidgetBackgroundBrush" Color="#2C2C2E"/>
            <SolidColorBrush x:Key="CardBackgroundBrush" Color="#2C2C2E"/>
            <SolidColorBrush x:Key="WidgetBorderBrush" Color="#3A3A3C"/>
            <SolidColorBrush x:Key="SecondaryTextBrush" Color="#98989F"/>
            <SolidColorBrush x:Key="CompletedTextBrush" Color="#6E6E73"/>
            <SolidColorBrush x:Key="MutedIconBrush" Color="#8A8A90"/>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- ===== Section tones (same both themes; tints are translucent so
              they read on light and dark backgrounds alike) ===== -->
    <SolidColorBrush x:Key="HomeAccentBrush" Color="#5B8DEF"/>
    <SolidColorBrush x:Key="HomeTintBrush" Color="#2A5B8DEF"/>
    <SolidColorBrush x:Key="CalAccentBrush" Color="#34B687"/>
    <SolidColorBrush x:Key="CalTintBrush" Color="#2A34B687"/>
    <SolidColorBrush x:Key="NotesAccentBrush" Color="#F0A24E"/>
    <SolidColorBrush x:Key="NotesTintBrush" Color="#2AF0A24E"/>
    <SolidColorBrush x:Key="SettingsAccentBrush" Color="#A98EDA"/>
    <SolidColorBrush x:Key="SettingsTintBrush" Color="#2AA98EDA"/>

    <!-- ===== Primary accent (soft blue) ===== -->
    <Color x:Key="AppAccentColor">#5B8DEF</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="#5B8DEF"/>
    <SolidColorBrush x:Key="OverdueBrush" Color="#E5707E"/>

    <!-- Recolor the WinUI system-accent family -> soft blue -->
    <Color x:Key="SystemAccentColor">#5B8DEF</Color>
    <Color x:Key="SystemAccentColorLight1">#71A0F2</Color>
    <Color x:Key="SystemAccentColorLight2">#8AB2F5</Color>
    <Color x:Key="SystemAccentColorLight3">#A6C6F8</Color>
    <Color x:Key="SystemAccentColorDark1">#4E7CD8</Color>
    <Color x:Key="SystemAccentColorDark2">#436CC0</Color>
    <Color x:Key="SystemAccentColorDark3">#385BA6</Color>

    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#5B8DEF"/>
    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#5283E0"/>
    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#4E7CD8"/>

    <!-- White text on the accent (buttons, toggles) -->
    <SolidColorBrush x:Key="TextOnAccentFillColorPrimaryBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextOnAccentFillColorSecondaryBrush" Color="#F0F0F0"/>

    <!-- ===== Rounder corners for an iOS feel ===== -->
    <CornerRadius x:Key="ControlCornerRadius">9</CornerRadius>
    <CornerRadius x:Key="OverlayCornerRadius">14</CornerRadius>

    <!-- ===== Typography ===== -->
    <x:Double x:Key="SectionTitleFontSize">22</x:Double>
    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource SectionTitleFontSize}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin" Value="2,0,0,8"/>
    </Style>

    <!-- ===== Grouped card ===== -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{ThemeResource WidgetBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Padding" Value="14"/>
    </Style>

    <!-- ===== Dashboard tile (soft tinted, centered) ===== -->
    <Style x:Key="TileButtonStyle" TargetType="Button">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Padding" Value="12"/>
        <Setter Property="Margin" Value="6"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>
</ResourceDictionary>
