<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="AccentColor">#4A90D9</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="WidgetBackgroundBrush" Color="#F5F5F7" />
    <SolidColorBrush x:Key="WidgetBorderBrush" Color="#E0E0E5" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#6B6B70" />
    <SolidColorBrush x:Key="CompletedTextBrush" Color="#9A9AA0" />

    <x:Double x:Key="SectionTitleFontSize">20</x:Double>
    <x:Double x:Key="ClockFontSize">48</x:Double>
    <x:Double x:Key="BodyFontSize">14</x:Double>

    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource SectionTitleFontSize}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style x:Key="DragBarStyle" TargetType="Border">
        <Setter Property="Height" Value="32" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
</ResourceDictionary>
